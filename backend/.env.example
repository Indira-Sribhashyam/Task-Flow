# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values
# cp .env.example .env
# ─────────────────────────────────────────────

# MongoDB connection string
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/collab-board

# JWT Secret — used to sign and verify auth tokens
# Generate a strong one with this command in your terminal:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# Port the Express server listens on
PORT=5000
